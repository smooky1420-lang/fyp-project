# Copy to .env in shems-backend/ (manage.py loads via python-dotenv)

# --- Django (production) ---
# SECRET_KEY=generate-a-long-random-string
# DEBUG=False
# ALLOWED_HOSTS=your-domain.com,192.168.1.50

# --- Solar weather (optional) ---
# Without this, solar uses estimated daylight/cloud — still works for demos
OPENWEATHER_API_KEY=

# Get a free key: https://openweathermap.org/api
